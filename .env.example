# 飞书凭证通过 macOS Keychain 读取，无需写在 .env 中
# 请打开 Keychain Access 添加以下两项：
#
# 1. 名称: FEISHU_APP
#    帐户: FEISHU_APP_ID
#    密码: <你的飞书应用 App Secret>
#
# 2. 名称: FEISHU_OPEN_ID
#    帐户: FEISHU_OPEN_ID
#    密码: <你的用户 open_id>
#
# FEISHU_APP_ID 通过环境变量设置（非敏感信息）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxxx

# 可选配置
TRENDING_COUNT=5
CACHE_DIR=
